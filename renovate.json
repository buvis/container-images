{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>tbouska/renovate-config", "customManagers:dockerfileVersions"],
  "mise": {
    "managerFilePatterns": ["**/assets/config/mise/config.toml"]
  },
  "packageRules": [
    {
      "matchPackageNames": ["python"],
      "matchManagers": ["mise"],
      "groupName": "python"
    }
  ]
}
