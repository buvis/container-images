{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>tbouska/renovate-config", "customManagers:dockerfileVersions"],
  "mise": {
    "managerFilePatterns": ["**/assets/config/mise/config.toml"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/koolna-images-configmap\\.yaml$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s+[A-Z_]+:\\s+\"[^\"]+:(?<currentValue>[^\"@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)\""
      ]
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["python"],
      "matchManagers": ["mise"],
      "groupName": "python"
    },
    {
      "matchManagers": ["mise"],
      "matchFileNames": ["base/koolna-dev/assets/config/mise/config.toml"],
      "matchPackageNames": ["!python"],
      "groupName": "koolna-dev mise tools"
    },
    {
      "matchPackageNames": [
        "k8s.io/api",
        "k8s.io/apimachinery",
        "k8s.io/client-go",
        "k8s.io/apiextensions-apiserver",
        "k8s.io/apiserver",
        "k8s.io/component-base",
        "sigs.k8s.io/controller-runtime"
      ],
      "matchManagers": ["gomod"],
      "groupName": "kubernetes",
      "allowedVersions": "<0.36.0"
    }
  ]
}
